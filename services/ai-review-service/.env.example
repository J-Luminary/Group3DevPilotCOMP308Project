# Copy to repo root `.env` for local dev, or set these on Render for `ai-review-service` only.

# LLM chain (review + reflection): Groq runs first when set
GROQ_API_KEY=your-groq-key-here

# LLM chain: Gemini fallback
GEMINI_API_KEY=your-gemini-key-here

# Embeddings for RAG: Cohere is used first if set; else Gemini embeddings
COHERE_API_KEY=your-cohere-key-here
# Optional Cohere embedding model (default: embed-english-v3.0)
# COHERE_EMBED_MODEL=embed-english-v3.0
